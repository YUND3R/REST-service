proxy_pass https://ml_balancer_svc;
proxy_http_version 2.0;
proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_set_header Connection "";
proxy_ssl_server_name on;
proxy_ssl_name intercluster.ml.example.invalid;
proxy_ssl_trusted_certificate /etc/nginx/tls/ml-server-ca/ca.crt;
proxy_ssl_verify on;
proxy_ssl_verify_depth 3;
proxy_ssl_session_reuse on;
proxy_ssl_certificate /etc/nginx/tls/gateway-client/tls.crt;
proxy_ssl_certificate_key /etc/nginx/tls/gateway-client/tls.key;
